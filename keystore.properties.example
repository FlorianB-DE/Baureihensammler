# Copy to keystore.properties in the project root and fill in.
# Create keystore once, e.g. (PowerShell, project root):
# keytool -genkey -v -keystore baureihensammler-release.jks -keyalg RSA -keysize 2048 -validity 10000 -alias baureihensammler
#
# For Play Console with "Google Play App Signing", this key is your "upload key".

storeFile=baureihensammler-release.jks
storePassword=your-store-password
keyAlias=baureihensammler
keyPassword=your-key-password
